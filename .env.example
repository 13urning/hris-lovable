# CLOUD_SQL_UNIX_SOCKET=/cloudsql/wave-hris-498916:us-central1:wave-hris

# Firebase
FIREBASE_PROJECT_ID=wave-hris-fb
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here
